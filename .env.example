APP_NAME=financial-statement-fraud-detection
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

VNSTOCK_API_KEY=your_vnstock_api_key_here

DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
ARTIFACTS_DIR=data/artifacts
MODEL_DIR=data/artifacts/models
REPORT_DIR=data/artifacts/reports

RANDOM_STATE=42
